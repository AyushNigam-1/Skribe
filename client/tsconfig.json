{
    "compilerOptions": {
        "target": "ESNext",
        "useDefineForClassFields": true,
        "lib": [
            "DOM",
            "DOM.Iterable",
            "ESNext"
        ],
        "allowJs": false,
        "skipLibCheck": true,
        "esModuleInterop": false,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "module": "ESNext",
        "moduleResolution": "Node",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "types": [
            "vite/client",
            "node"
        ]
    },
    "include": [
        "src",
        "playwright.config.ts",
        "__tests__",
        "../server/src/tests/pact/pact_server.ts",
        "../server/src/tests/pact/states/paragraphMutationStates.ts",
        "../server/src/tests/instrumentation.ts"
    ]
}