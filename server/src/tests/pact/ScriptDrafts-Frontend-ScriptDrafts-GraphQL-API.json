{
  "consumer": {
    "name": "ScriptDrafts-Frontend"
  },
  "interactions": [
    {
      "description": "a request for user notifications",
      "providerStates": [
        {
          "name": "user 60c72b2f9b1d8b001c8e4a01 has notifications"
        }
      ],
      "request": {
        "body": {
          "operationName": "GetNotifications",
          "query": "query GetNotifications($userId: ID!) {\n  getNotifications(userId: $userId) {\n    id\n    type\n    message\n    draftTitle\n    link\n    isRead\n    createdAt\n    sender {\n      id\n      name\n    }\n  }\n}",
          "variables": {
            "userId": "60c72b2f9b1d8b001c8e4a01"
          }
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "method": "POST",
        "path": "/graphql"
      },
      "response": {
        "body": {
          "data": {
            "getNotifications": [
              {
                "createdAt": "1704153600000",
                "id": "60c72b2f9b1d8b001c8e4a06",
                "message": "You have a new comment.",
                "read": false,
                "type": "comment"
              }
            ]
          }
        },
        "headers": {
          "Content-Type": "application/json; charset=utf-8"
        },
        "matchingRules": {
          "body": {
            "$.data.getNotifications[0].createdAt": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.getNotifications[0].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.getNotifications[0].message": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.getNotifications[0].read": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.getNotifications[0].type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "17.0.0"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "ScriptDrafts-GraphQL-API"
  }
}